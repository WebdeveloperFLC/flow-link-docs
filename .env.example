# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Institutions module (optional — safe production defaults)
# VITE_USE_MOCK_DATA=false
# VITE_ALLOW_TEST_DELETIONS=false
# Optional — high-quality institution logos (free tier at logo.dev; Clearbit shut down Dec 2025)
# VITE_LOGO_DEV_TOKEN=pk_your_publishable_key

# Dashboard V2 — hide go-live widgets until modules are in production use
# VITE_DASHBOARD_ASSESSMENTS_ENABLED=false
# VITE_DASHBOARD_OFFERS_ENABLED=false

# O14 — legacy service_offers convergence (Phase 6D)
# VITE_LEGACY_OFFERS_READ_ONLY=false
# VITE_LEGACY_OFFERS_RETIREMENT_DATE=December 2026

# WhatsApp helpline inbox
VITE_WHATSAPP_ENABLED=true
# mock | meta | auto (auto = meta when Supabase secrets configured)
VITE_WHATSAPP_PROVIDER=mock

# Phase 1 — set in Supabase Edge secrets (not VITE_*):
# WHATSAPP_PROVIDER=meta
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_AI_MODE=rules
# WHATSAPP_WEBHOOK_SECRET=optional-for-simulate-only

# Setup guide: docs/guides/whatsapp-phase1-meta-setup.md

# HR Payroll live DB smoke (optional — local only, never commit secrets)
# HR_INTEGRATION_TEST=1
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# HR_INTEGRATION_TEST_STRICT=1  # fail if training migrations not published on remote
