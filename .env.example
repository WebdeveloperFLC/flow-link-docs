# Supabase (required)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Institutions module (optional — safe production defaults)
# VITE_USE_MOCK_DATA=false
# VITE_ALLOW_TEST_DELETIONS=false

# WhatsApp helpline inbox
VITE_WHATSAPP_ENABLED=true
# mock | meta | auto (auto = meta when Supabase secrets configured)
VITE_WHATSAPP_PROVIDER=mock

# Phase 1 — set in Supabase Edge secrets (not VITE_*):
# WHATSAPP_PROVIDER=meta
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_APP_SECRET=
# WHATSAPP_AI_MODE=rules
# WHATSAPP_WEBHOOK_SECRET=optional-for-simulate-only

# Setup guide: docs/guides/whatsapp-phase1-meta-setup.md
