  "faqs": [
    {
      "q": "Can we guarantee visitor visa?",
      "a": "No. INZ decides each case individually."
    },
    {
      "q": "How much funds?",
      "a": "Enough for trip duration—no fixed amount but must be credible."
    },
    {
      "q": "Can visitor work?",
      "a": "No. Work not permitted on visitor visa."
    },
    {
      "q": "Can switch to student in NZ?",
      "a": "Generally must apply from outside NZ—verify current rules."
    },
    {
      "q": "Reapply after refusal?",
      "a": "Yes when circumstances improve."
    },
    {
      "q": "Invitation letter needed?",
      "a": "Recommended for family visits."
    },
    {
      "q": "Processing time?",
      "a": "Typically 3–6 weeks standard."
    },
    {
      "q": "Multiple entry?",
      "a": "Officer decides visa conditions at approval."
    }
