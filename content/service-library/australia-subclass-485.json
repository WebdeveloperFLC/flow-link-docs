  "faqs": [
    {
      "q": "Can we guarantee 485 approval?",
      "a": "No. Most eligible graduates approved but never guarantee."
    },
    {
      "q": "Post-Study Work vs Graduate Work?",
      "a": "Post-Study Work based on degree level; Graduate Work requires skills assessment for nominated occupation."
    },
    {
      "q": "How long is 485?",
      "a": "2–4 years depending on qualification level and stream—verify current rules."
    },
    {
      "q": "Can apply from outside Australia?",
      "a": "Generally must hold eligible visa in Australia—verify current rules for offshore apply."
    },
    {
      "q": "Can include partner?",
      "a": "Yes—partner and children can be included; additional fees and evidence."
    },
    {
      "q": "Path to PR?",
      "a": "Australian work experience on 485 supports skilled migration points."
    },
    {
      "q": "When does 6 months start?",
      "a": "From course completion date on official completion letter."
    },
    {
      "q": "Can work any job on 485?",
      "a": "Yes—open work rights on Post-Study Work Stream."
    }
  ],
