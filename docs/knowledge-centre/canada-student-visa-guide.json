      "no": 10,
      "key": "faqs",
      "title": "FAQs",
      "owner": "futureLink",
      "purpose": "Standardise honest, consistent answers.",
      "counsellingObjective": "The client's common questions are answered consistently and honestly.",
      "contentClassification": [
        "Future Link Content",
        "Official Reference"
      ],
      "body": {
        "counsellorGuidance": "Answers link, never quote figures.",
        "items": [
          {
            "q": "Can Future Link guarantee a visa?",
            "a": "No — we prepare; IRCC decides.",
            "reference": null
          },
          {
            "q": "How much money is needed?",
            "a": "Confirm current threshold.",
            "reference": "IRCC"
          },
          {
            "q": "Do I need a PAL/TAL?",
            "a": "Depends on category.",
            "reference": "IRCC"
          },
          {
            "q": "Are grad students exempt from PAL?",
            "a": "Often, at public DLIs.",
            "reference": "IRCC"
          },
          {
            "q": "Is a GIC required?",
            "a": "One accepted option.",
            "reference": "IRCC"
          },
          {
            "q": "Where do I apply?",
            "a": "Online via IRCC/GCKey.",
            "reference": "IRCC"
          },
          {
            "q": "Do I need biometrics?",
            "a": "Most applicants do.",
            "reference": "IRCC"
          },
          {
            "q": "Is a medical required?",
            "a": "Country/course dependent.",
            "reference": "IRCC"
          },
          {
            "q": "How long does it take?",
            "a": "Varies; check processing times.",
            "reference": "IRCC"
          },
          {
            "q": "Can I work while studying?",
            "a": "Per current rule.",
            "reference": "IRCC"
          },
          {
            "q": "Can my spouse work?",
            "a": "Eligibility narrowed; per rule.",
            "reference": "IRCC"
          },
          {
            "q": "What about Quebec?",
            "a": "CAQ applies.",
            "reference": "IRCC/Quebec"
          },
          {
            "q": "Does field of study matter?",
            "a": "Yes, for some PGWPs.",
            "reference": "IRCC"
          },
          {
            "q": "Must I disclose past refusals?",
            "a": "Always yes.",
            "reference": null
          },
          {
            "q": "When should I start?",
            "a": "Early — allocations fill.",
            "reference": "IRCC"
          },
          {
            "q": "Can I change program later?",
            "a": "It can trigger scrutiny.",
            "reference": "IRCC"
          },
          {
            "q": "What is a DLI?",
            "a": "A school authorised to host international students.",
            "reference": "IRCC"
          },
          {
            "q": "What documents do I need?",
            "a": "See Eligibility Summary / Document Library.",
            "reference": "Document Library"
          },
          {
            "q": "Who issues the permit & when?",
            "a": "IRCC approves; issued at port of entry.",
            "reference": "IRCC"
          },
          {
            "q": "Can I apply on paper?",
            "a": "Apply online.",
            "reference": "IRCC"
          },
          {
            "q": "What if I'm refused?",
            "a": "Review grounds; reapply / JR options.",
            "reference": "IRCC"
          },
          {
            "q": "What happens at the airport?",
            "a": "Identity/biometric check, then permit.",
            "reference": "IRCC"
          },
          {
            "q": "Can my parents visit?",
            "a": "Visitor route.",
            "reference": "IRCC"
          },
          {
            "q": "When can I work after graduating?",
            "a": "Via PGWP.",
            "reference": "IRCC"
          },
          {
            "q": "What does Future Link actually do?",
            "a": "Counselling, prep, settlement.",
            "reference": null
          }
        ]
      }
